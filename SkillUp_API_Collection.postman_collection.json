{
    "info": {
        "name": "SkillUp API - Full Workflow",
        "description": "Complete API testing collection for SkillUp database integration",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Login as Instructor",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"instructor@skillup.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/auth/login",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "2. Create Course (Instructor)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{instructor_token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Postman Test Course\",\n  \"subtitle\": \"Testing database integration\",\n  \"category\": \"Technology\",\n  \"level\": \"Beginner\",\n  \"language\": \"English\",\n  \"duration\": \"5h 30m\",\n  \"thumbnail\": \"https://images.unsplash.com/photo-1516321318423-f06f85e504b3\",\n  \"whatYouWillLearn\": [\n    \"How to test APIs with Postman\",\n    \"Database integration concepts\",\n    \"Course approval workflow\"\n  ],\n  \"skills\": [\"API Testing\", \"Backend Development\"],\n  \"includes\": [\"5h 30m on-demand video\", \"Full lifetime access\"],\n  \"requirements\": [\"Basic programming knowledge\"],\n  \"targetAudience\": [\"Developers\", \"Students\"],\n  \"price\": 49.99,\n  \"originalPrice\": 79.99,\n  \"hasMoneyBackGuarantee\": true,\n  \"modules\": [\n    {\n      \"id\": \"mod1\",\n      \"title\": \"Introduction\",\n      \"lessons\": [\n        {\n          \"id\": \"les1\",\n          \"title\": \"Welcome Video\",\n          \"type\": \"video\",\n          \"duration\": \"5:30\",\n          \"description\": \"Introduction to the course\"\n        }\n      ]\n    }\n  ]\n}"
                },
                "url": {
                    "raw": "{{base_url}}/instructor/courses",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "instructor",
                        "courses"
                    ]
                }
            }
        },
        {
            "name": "3. Get Instructor Courses",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{instructor_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/instructor/courses",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "instructor",
                        "courses"
                    ]
                }
            }
        },
        {
            "name": "4. Submit Course for Review",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{instructor_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/instructor/courses/{{course_id}}/submit",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "instructor",
                        "courses",
                        "{{course_id}}",
                        "submit"
                    ]
                }
            }
        },
        {
            "name": "5. Login as Admin",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"admin@skillup.com\",\n  \"password\": \"admin123\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/auth/login",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "6. Get Pending Courses (Admin)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{admin_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/admin/courses/pending",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "admin",
                        "courses",
                        "pending"
                    ]
                }
            }
        },
        {
            "name": "7. Approve Course (Admin)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{admin_token}}"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/admin/courses/{{course_id}}/approve",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "admin",
                        "courses",
                        "{{course_id}}",
                        "approve"
                    ]
                }
            }
        },
        {
            "name": "8. Get Published Courses (Public)",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/courses",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "courses"
                    ]
                }
            }
        },
        {
            "name": "Extra: Reject Course (Admin)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{admin_token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"reason\": \"Course content needs improvement. Please add more detailed examples.\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/admin/courses/{{course_id}}/reject",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "admin",
                        "courses",
                        "{{course_id}}",
                        "reject"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000/api"
        },
        {
            "key": "instructor_token",
            "value": "PASTE_INSTRUCTOR_TOKEN_HERE"
        },
        {
            "key": "admin_token",
            "value": "PASTE_ADMIN_TOKEN_HERE"
        },
        {
            "key": "course_id",
            "value": "PASTE_COURSE_ID_HERE"
        }
    ]
}